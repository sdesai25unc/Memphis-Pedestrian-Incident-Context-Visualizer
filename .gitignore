# ── Python virtual environment & caches ───────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Vercel local CLI artifacts (dashboard deploy doesn't create these) ──
.vercel/

# ── Secrets: belt-and-suspenders (the AI incident tool was removed 2026-07-13; no code
#    reads this file anymore, but keep the rule so a stray key can never be committed) ──
openai_key.txt

# ── OS / editor junk ──────────────────────────────────────────────
.vscode/
desktop.ini
.DS_Store
Thumbs.db

# ── Raw API page-dumps (intermediate scratch) ─────────────────────
# The consolidated .geojson files are the usable form and are kept.
# These raw pages are re-downloaded by scripts 01 / 02 / 05.
data/raw/*_page_*.json
data/raw/memphis_boundary.json

# ── Large regenerable data (rebuilt by script 05) ─────────────────
# 91 MB full street network; excluded to keep the repo light.
data/raw/memphis_streets.geojson

# ── City sidewalk inventory: source zip + extracted .gdb stay out of the repo.
#    The reprojected working file (data/processed/memphis_sidewalks_32136.geojson) is
#    COMMITTED as of 2026-07-14 — redistribution permission granted by the city (July 2026).
Memphis_Sidewalks_DMC*.zip
data/raw/sidewalks_dmc/

