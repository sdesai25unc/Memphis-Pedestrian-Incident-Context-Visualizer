# These raw pages are re-downloaded by scripts 01 / 02 / 05.
data/raw/*_page_*.json
data/raw/memphis_boundary.json

# ── Large regenerable data (rebuilt by script 05) ─────────────────
# 91 MB full street network; excluded to keep the repo light.
data/raw/memphis_streets.geojson

